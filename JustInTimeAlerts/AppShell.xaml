<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="JustInTimeAlerts.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:JustInTimeAlerts"
    xmlns:views="clr-namespace:JustInTimeAlerts.Views"
    Title="JustInTimeAlerts">

    <TabBar>
        <Tab Title="Home" Icon="home.png">
            <ShellContent
                ContentTemplate="{DataTemplate local:MainPage}"
                Route="MainPage" />
        </Tab>
        <Tab Title="Log" Icon="debug.png">
            <ShellContent
                ContentTemplate="{DataTemplate views:LogPage}"
                Route="LogPage" />
        </Tab>
    </TabBar>

</Shell>
