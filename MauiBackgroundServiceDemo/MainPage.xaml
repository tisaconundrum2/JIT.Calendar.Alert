<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiBackgroundServiceDemo.MainPage"
             Title="Accelerometer Monitor">

    <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

        <Label Text="Accelerometer Background Service"
               FontSize="22"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <BoxView HeightRequest="1" Color="LightGray" />

        <!-- Status indicator -->
        <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
            <Ellipse x:Name="StatusDot"
                     WidthRequest="14" HeightRequest="14"
                     Fill="Gray"
                     VerticalOptions="Center" />
            <Label x:Name="StatusLabel"
                   Text="Waiting for readings…"
                   FontSize="14"
                   VerticalOptions="Center" />
        </HorizontalStackLayout>

        <!-- Live readings -->
        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="16" RowSpacing="12"
              Margin="0,10">

            <Label Grid.Row="0" Grid.Column="0" Text="X" FontAttributes="Bold" FontSize="18" TextColor="#E53935" />
            <Label x:Name="XLabel" Grid.Row="0" Grid.Column="1" Text="—" FontSize="18" FontFamily="OpenSansRegular" />

            <Label Grid.Row="1" Grid.Column="0" Text="Y" FontAttributes="Bold" FontSize="18" TextColor="#43A047" />
            <Label x:Name="YLabel" Grid.Row="1" Grid.Column="1" Text="—" FontSize="18" FontFamily="OpenSansRegular" />

            <Label Grid.Row="2" Grid.Column="0" Text="Z" FontAttributes="Bold" FontSize="18" TextColor="#1E88E5" />
            <Label x:Name="ZLabel" Grid.Row="2" Grid.Column="1" Text="—" FontSize="18" FontFamily="OpenSansRegular" />

        </Grid>

        <BoxView HeightRequest="1" Color="LightGray" />

        <Label x:Name="ReadingCountLabel"
               Text="Readings received: 0"
               FontSize="13"
               TextColor="Gray"
               HorizontalOptions="Center" />

        <Label Text="Minimize the app — the service keeps running."
               FontSize="12"
               TextColor="Gray"
               HorizontalTextAlignment="Center" />

    </VerticalStackLayout>

</ContentPage>
